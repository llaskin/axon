#!/usr/bin/env bash
# axon-collect — Gather dendrite signals for a project
# Called by: axon collect, or axon rollup (as a pre-step)
# Writes to: ~/.axon/workspaces/{project}/dendrites/

set -euo pipefail

# Inherited from parent axon script
AXON_HOME="${AXON_HOME:-$HOME/.axon}"
PROJECT="${PROJECT:-$(basename "$PWD")}"
PROJECT_PATH="${PROJECT_PATH:-$PWD}"
WORKSPACE="$AXON_HOME/workspaces/$PROJECT"
DENDRITE_DIR="$WORKSPACE/dendrites"
LAST_FILE="$DENDRITE_DIR/.last-collection"
NOW=$(date -u +"%Y-%m-%dT%H-%M-%SZ")

mkdir -p "$DENDRITE_DIR"

# Read project config for dendrite settings
CONFIG_FILE="$WORKSPACE/config.yaml"
dendrite_enabled() {
    local dtype="$1"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        # No config — enable all by default
        return 0
    fi
    # Check for "dtype:\n    enabled: false" pattern
    local enabled
    enabled=$(awk "/^  ${dtype}:/{found=1} found && /enabled:/{print \$2; exit}" "$CONFIG_FILE" 2>/dev/null)
    if [[ "$enabled" == "false" ]]; then
        return 1
    fi
    return 0
}

# Read max_commits from config (default 200)
MAX_COMMITS=200
if [[ -f "$CONFIG_FILE" ]]; then
    _mc=$(awk '/max_commits:/{print $2}' "$CONFIG_FILE" 2>/dev/null)
    [[ -n "$_mc" ]] && [[ "$_mc" =~ ^[0-9]+$ ]] && MAX_COMMITS="$_mc"
fi

# Determine time window
if [[ -n "${SINCE:-}" ]]; then
    GIT_SINCE="$SINCE"
elif [[ -f "$LAST_FILE" ]]; then
    GIT_SINCE=$(cat "$LAST_FILE")
else
    GIT_SINCE="24 hours ago"
fi

echo "Collecting dendrites for $PROJECT..."
echo "  Path: $PROJECT_PATH"
echo "  Since: $GIT_SINCE"

# --- GIT-LOG DENDRITE ---
if ! dendrite_enabled "git-log"; then
    echo "  · git-log: disabled in config"
elif git -C "$PROJECT_PATH" rev-parse --git-dir > /dev/null 2>&1; then
    COMMIT_COUNT=$(git -C "$PROJECT_PATH" log --since="$GIT_SINCE" --oneline -"$MAX_COMMITS" 2>/dev/null | wc -l | tr -d ' ')

    if [[ "$COMMIT_COUNT" -gt 0 ]]; then
        OUTFILE="$DENDRITE_DIR/${NOW}_git-log.md"

        # Frontmatter
        cat > "$OUTFILE" << EOF
---
type: git-log
project: $PROJECT
collected_at: $(echo "$NOW" | sed 's/T\([0-9]*\)-\([0-9]*\)-\([0-9]*\)Z/T\1:\2:\3Z/')
since: $GIT_SINCE
commit_count: $COMMIT_COUNT
branch: $(git -C "$PROJECT_PATH" branch --show-current 2>/dev/null || echo "unknown")
---

# Git Log: $PROJECT

## Commits ($COMMIT_COUNT)

EOF

        # Each commit with files
        git -C "$PROJECT_PATH" log --since="$GIT_SINCE" \
            --format="### %s%n- **SHA:** %h%n- **Time:** %aI%n- **Author:** %an%n" \
            >> "$OUTFILE"

        # Diff stats
        echo "" >> "$OUTFILE"
        echo "## Diff Stats" >> "$OUTFILE"
        git -C "$PROJECT_PATH" log --since="$GIT_SINCE" --stat --format="" \
            | tail -1 >> "$OUTFILE" 2>/dev/null || true

        # Most-touched files
        echo "" >> "$OUTFILE"
        echo "## Most-Touched Files" >> "$OUTFILE"
        git -C "$PROJECT_PATH" log --since="$GIT_SINCE" --name-only --format="" \
            | grep -v '^$' | sort | uniq -c | sort -rn | head -15 \
            | while read count file; do
                echo "- \`$file\` ($count changes)" >> "$OUTFILE"
            done

        echo "  ✓ git-log: $COMMIT_COUNT commits"
    else
        echo "  · git-log: no commits since $GIT_SINCE"
    fi
else
    echo "  · git-log: not a git repository"
fi

# --- FILE-TREE DENDRITE ---
if ! dendrite_enabled "file-tree"; then
    echo "  · file-tree: disabled in config"
elif git -C "$PROJECT_PATH" rev-parse --git-dir > /dev/null 2>&1; then
    OUTFILE="$DENDRITE_DIR/${NOW}_file-tree.md"
    TREE_HASH=$(git -C "$PROJECT_PATH" ls-files | shasum -a 256 | awk '{print $1}')
    FILE_COUNT=$(git -C "$PROJECT_PATH" ls-files | wc -l | tr -d ' ')

    # Check previous hash
    PREV_HASH=""
    PREV_TREE=$(find "$DENDRITE_DIR" -name "*_file-tree.md" -print 2>/dev/null | sort -r | head -1)
    if [[ -n "${PREV_TREE:-}" ]] && [[ -f "$PREV_TREE" ]]; then
        PREV_HASH=$(grep "tree_hash:" "$PREV_TREE" 2>/dev/null | awk '{print $2}' || true)
    fi

    cat > "$OUTFILE" << EOF
---
type: file-tree
project: $PROJECT
collected_at: $(echo "$NOW" | sed 's/T\([0-9]*\)-\([0-9]*\)-\([0-9]*\)Z/T\1:\2:\3Z/')
tree_hash: $TREE_HASH
previous_tree_hash: ${PREV_HASH:-none}
total_files: $FILE_COUNT
---

# File Tree: $PROJECT

EOF

    if [[ -n "$PREV_HASH" ]] && [[ "$TREE_HASH" != "$PREV_HASH" ]]; then
        echo "## Changes (hash differs from previous)" >> "$OUTFILE"
        # Show added/removed files
        git -C "$PROJECT_PATH" diff --name-status HEAD~5 HEAD 2>/dev/null >> "$OUTFILE" || true
    elif [[ -z "$PREV_HASH" ]]; then
        echo "## Initial snapshot" >> "$OUTFILE"
        echo "Total tracked files: $FILE_COUNT" >> "$OUTFILE"
    else
        echo "## No structural changes" >> "$OUTFILE"
    fi

    echo "  ✓ file-tree: $FILE_COUNT files (hash: ${TREE_HASH:0:12}...)"
else
    echo "  · file-tree: not a git repository"
fi

# --- STREAM DENDRITE (from axon log notes) ---
if ! dendrite_enabled "manual-note"; then
    echo "  · stream: disabled in config"
elif [[ -f "$WORKSPACE/stream.md" ]]; then
    # Determine cutoff timestamp for filtering
    if [[ -f "$LAST_FILE" ]]; then
        CUTOFF=$(cat "$LAST_FILE")
    else
        CUTOFF=""
    fi

    # Pull @user entries since last collection
    STREAM_ENTRIES=""
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if echo "$line" | grep -q '@user:'; then
            # If we have a cutoff, only include entries newer than it
            if [[ -n "$CUTOFF" ]]; then
                ENTRY_TS=$(echo "$line" | sed -n 's/.*\[\([^]]*\)\].*/\1/p')
                if [[ -n "$ENTRY_TS" ]] && [[ "$ENTRY_TS" > "$CUTOFF" ]]; then
                    STREAM_ENTRIES+="$line
"
                fi
            else
                STREAM_ENTRIES+="$line
"
            fi
        fi
    done < "$WORKSPACE/stream.md"

    if [[ -n "$STREAM_ENTRIES" ]]; then
        STREAM_COUNT=$(echo "$STREAM_ENTRIES" | grep -c '@user:' || true)
        OUTFILE="$DENDRITE_DIR/${NOW}_stream.md"
        cat > "$OUTFILE" << EOF
---
type: stream
project: $PROJECT
collected_at: $(echo "$NOW" | sed 's/T\([0-9]*\)-\([0-9]*\)-\([0-9]*\)Z/T\1:\2:\3Z/')
entry_count: $STREAM_COUNT
---

# Stream Notes: $PROJECT

$STREAM_ENTRIES
EOF
        echo "  ✓ stream: $STREAM_COUNT user notes"
    else
        echo "  · stream: no user notes"
    fi
else
    echo "  · stream: no stream.md"
fi

# NOTE: .last-collection is NOT updated here.
# axon-rollup updates it after successful rollup to avoid losing signals on failure.

echo ""
echo "Done. Dendrites in $DENDRITE_DIR/"
ls -1 "$DENDRITE_DIR/${NOW}"* 2>/dev/null | sed 's/.*\//  /'
