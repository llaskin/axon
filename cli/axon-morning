#!/usr/bin/env bash
# axon-morning — Conversational morning briefing + interactive session
# Reads latest rollup + state, delivers briefing, then opens a chat
# If you've been away, automatically runs a catch-up rollup first
# Supports --all for multi-project briefing across active projects
# Conversation is stored in ~/.axon/workspaces/{project}/mornings/

set -euo pipefail

AXON_HOME="${AXON_HOME:-$HOME/.axon}"
PROJECT="${PROJECT:-$(basename "$PWD")}"
PROJECT_PATH="${PROJECT_PATH:-$PWD}"
WORKSPACE="$AXON_HOME/workspaces/$PROJECT"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROTOCOL="$SCRIPT_DIR/../protocol.md"
TODAY=$(date +%Y-%m-%d)
ALL_PROJECTS="${ALL_PROJECTS:-}"

# --- Helper: read status from config.yaml ---
read_status() {
    local config="$1"
    if [[ -f "$config" ]]; then
        grep "^status:" "$config" 2>/dev/null | awk '{print $2}' || echo "active"
    else
        echo "active"
    fi
}

# --- Helper: get project headline from latest rollup ---
read_headline() {
    local ws="$1"
    local latest_ep
    latest_ep=$(find "$ws/episodes" -name "*.md" -print 2>/dev/null | sort -r | head -1)
    if [[ -n "${latest_ep:-}" ]] && [[ -f "$latest_ep" ]]; then
        grep "^headline:" "$latest_ep" 2>/dev/null | sed 's/^headline: *//' | sed 's/^"//' | sed 's/"$//' || echo ""
    fi
}

# ====================================
# MULTI-PROJECT MODE (--all)
# ====================================
if [[ -n "$ALL_PROJECTS" ]]; then
    MORNING_DIR="$AXON_HOME/mornings"
    mkdir -p "$MORNING_DIR"

    SESSION_MARKER="$MORNING_DIR/${TODAY}.started"

    # Resume existing multi-project session
    if [[ -f "$SESSION_MARKER" ]]; then
        echo "Resuming morning session (all projects)..."
        echo ""
        exec claude --continue \
            2> >(tee -a "$MORNING_DIR/${TODAY}.log" >&2)
    fi

    # Gather context from all active projects
    echo "Scanning active projects..."
    echo ""

    PROJECT_SUMMARIES=""
    ACTIVE_COUNT=0

    for ws in "$AXON_HOME/workspaces"/*/; do
        [[ ! -d "$ws" ]] && continue
        name=$(basename "$ws")
        config="$ws/config.yaml"
        state="$ws/state.md"

        status=$(read_status "$config")
        [[ "$status" != "active" ]] && continue

        ((ACTIVE_COUNT++))

        # Read state
        ws_state=""
        if [[ -f "$state" ]]; then
            ws_state=$(cat "$state")
        fi

        # Read latest rollup (first 60 lines)
        ws_rollup=""
        latest_ep=$(find "$ws/episodes" -name "*.md" -print 2>/dev/null | sort -r | head -1)
        if [[ -n "${latest_ep:-}" ]] && [[ -f "$latest_ep" ]]; then
            ws_rollup=$(head -60 "$latest_ep")
        fi

        # Last rollup date
        last_rollup=$(grep "last_rollup:" "$state" 2>/dev/null | awk '{print $2}' | head -1)

        # Open loops count
        open_loops=$(grep -c '^\s*- \[ \]\|^\s*- \[>\]' "$state" 2>/dev/null || echo "0")

        # Headline from latest rollup
        headline=$(read_headline "$ws")

        echo "  ● $name (last: ${last_rollup:-never}, $open_loops open loops)"

        PROJECT_SUMMARIES+="
---
## Project: $name
Last rollup: ${last_rollup:-never}
Open loops: $open_loops
Headline: ${headline:-no recent rollup}

### State
$ws_state

### Latest Rollup (excerpt)
$ws_rollup
"
    done

    if [[ "$ACTIVE_COUNT" -eq 0 ]]; then
        echo "No active projects found. Initialize one with: axon init --project NAME --path /path"
        exit 1
    fi

    echo ""
    echo "  $ACTIVE_COUNT active projects"
    echo ""

    # Load protocol
    PROTOCOL_TEXT=""
    if [[ -f "$PROTOCOL" ]]; then
        PROTOCOL_TEXT=$(cat "$PROTOCOL")
    fi

    SYSTEM_CONTEXT="$PROTOCOL_TEXT

## Multi-Project Morning Briefing

You are delivering a morning briefing across $ACTIVE_COUNT projects. The developer manages all of these. Your job:

1. **Open with the big picture** — one sentence on overall status. How many projects, total open loops, anything urgent.
2. **Per-project summary** — for each active project, 2-3 lines: what happened recently, what's the top priority, any blockers.
3. **Cross-project priorities** — rank the top 3 things to do today across ALL projects. Highest leverage first.
4. **Offer to go deep** — ask which project they want to focus on first.

Be concise. This is a briefing, not a report. The developer should be oriented in under 60 seconds of reading.

## Project Data

$PROJECT_SUMMARIES"

    echo "Starting multi-project morning session..."
    echo ""
    touch "$SESSION_MARKER"
    exec claude \
        --append-system-prompt "$SYSTEM_CONTEXT" \
        2> >(tee -a "$MORNING_DIR/${TODAY}.log" >&2)
fi

# ====================================
# SINGLE-PROJECT MODE (default)
# ====================================

# Check initialized
if [[ ! -f "$WORKSPACE/state.md" ]]; then
    echo "Project '$PROJECT' is not initialized. Run: axon init --project $PROJECT"
    exit 1
fi

# Create mornings folder for conversation capture
MORNING_DIR="$WORKSPACE/mornings"
mkdir -p "$MORNING_DIR"

# --- Gap Detection ---
# How many days since the last rollup?
LAST_ROLLUP_DATE=$(grep "last_rollup:" "$WORKSPACE/state.md" 2>/dev/null | awk '{print $2}' | head -1)
DAYS_AWAY=0
GAP_CONTEXT=""

if [[ -n "$LAST_ROLLUP_DATE" ]] && [[ "$LAST_ROLLUP_DATE" != "none" ]] && [[ "$LAST_ROLLUP_DATE" != "genesis" ]]; then
    # Calculate days between last rollup and today
    if [[ "$(uname)" == "Darwin" ]]; then
        LAST_EPOCH=$(date -j -f "%Y-%m-%d" "$LAST_ROLLUP_DATE" "+%s" 2>/dev/null || echo "0")
        TODAY_EPOCH=$(date -j -f "%Y-%m-%d" "$TODAY" "+%s")
    else
        LAST_EPOCH=$(date -d "$LAST_ROLLUP_DATE" "+%s" 2>/dev/null || echo "0")
        TODAY_EPOCH=$(date -d "$TODAY" "+%s")
    fi

    if [[ "$LAST_EPOCH" != "0" ]]; then
        # Ceiling division — 23 hours should count as 1 day, not 0
        DIFF_SECS=$(( TODAY_EPOCH - LAST_EPOCH ))
        DAYS_AWAY=$(( (DIFF_SECS + 86399) / 86400 ))
    fi
fi

# If away more than 1 day, run a catch-up rollup
if [[ "$DAYS_AWAY" -gt 1 ]]; then
    echo "You've been away $DAYS_AWAY days (last rollup: $LAST_ROLLUP_DATE)."
    echo "Running catch-up rollup covering the gap..."
    echo ""

    # Acquire lockfile — prevent concurrent rollup from cron
    LOCKFILE="$WORKSPACE/.rollup.lock"
    if ! mkdir "$LOCKFILE" 2>/dev/null; then
        echo "A rollup is already in progress. Skipping catch-up."
        echo ""
        DAYS_AWAY=0
    fi

    if [[ "$DAYS_AWAY" -gt 1 ]]; then
    trap 'rmdir "$LOCKFILE" 2>/dev/null' EXIT INT TERM

    # Collect dendrites for the full gap
    export SINCE="${LAST_ROLLUP_DATE}"
    export PROJECT PROJECT_PATH AXON_HOME SCRIPT_DIR PROTOCOL
    "$SCRIPT_DIR/axon-collect"

    # Run catch-up rollup with gap-aware prompt
    DENDRITES=""
    for d in $(find "$WORKSPACE/dendrites" -name "*.md" -newer "$WORKSPACE/state.md" 2>/dev/null | sort); do
        DENDRITES+="
$(cat "$d")
---
"
    done

    STATE=$(cat "$WORKSPACE/state.md")
    PROTOCOL_TEXT=""
    if [[ -f "$PROTOCOL" ]]; then
        PROTOCOL_TEXT=$(cat "$PROTOCOL")
    fi

    echo ""
    echo "Generating catch-up rollup..."

    CATCHUP_RESULT=$(echo "You are Axon, running in headless mode. The developer has been away for $DAYS_AWAY days (since $LAST_ROLLUP_DATE). Produce a catch-up rollup covering the full gap.

## Protocol
$PROTOCOL_TEXT

## Current State (stale — from $LAST_ROLLUP_DATE)
$STATE

## Dendrite Signals (covering $DAYS_AWAY days)
$DENDRITES

## Task
Produce a catch-up rollup. This is NOT a normal daily rollup — the developer has been away. Include:
1. **Summary** — what happened across all $DAYS_AWAY days
2. **Key Decisions** — anything visible in commits
3. **What Changed** — major file/feature changes
4. **Unfinished Work** — use [>] for items that have been waiting
5. **Recommended Re-entry Point** — where should the developer start? What's the quickest way back into flow?

Tone: 'Welcome back. Here's what happened while you were gone.'

IMPORTANT: Output ONLY the rollup document. No preamble, no meta-commentary." | claude -p --output-format json --allowedTools "Read,Glob,Grep" 2>/dev/null)

    CATCHUP_TEXT=$(echo "$CATCHUP_RESULT" | jq -r '.result' 2>/dev/null)

    if [[ -n "$CATCHUP_TEXT" ]] && [[ "$CATCHUP_TEXT" != "null" ]]; then
        echo "$CATCHUP_TEXT" > "$WORKSPACE/episodes/${TODAY}_catchup.md"
        echo "  ✓ Catch-up rollup saved"

        # Update state
        NEW_STATE=$(echo "You are Axon. Update state.md after a $DAYS_AWAY day gap.

## Previous State (stale)
$STATE

## Catch-Up Rollup
$CATCHUP_TEXT

## Task
Regenerate state.md. Keep under 2000 tokens. Update all sections to reflect current reality after the gap. Add YAML frontmatter with last_rollup: $TODAY

IMPORTANT: Output ONLY the state.md content. No preamble, no meta-commentary." | claude -p --output-format json --allowedTools "Read,Glob,Grep" 2>/dev/null | jq -r '.result' 2>/dev/null)

        if [[ -n "$NEW_STATE" ]] && [[ "$NEW_STATE" != "null" ]]; then
            cp "$WORKSPACE/state.md" "$WORKSPACE/state.md.backup"
            TMPSTATE=$(mktemp "$WORKSPACE/.state.tmp.XXXXXX")
            echo "$NEW_STATE" > "$TMPSTATE" && mv "$TMPSTATE" "$WORKSPACE/state.md"
            echo "  ✓ State updated (atomic write)"
        fi

        # Update .last-collection after successful catch-up
        date -u +"%Y-%m-%dT%H:%M:%SZ" > "$WORKSPACE/dendrites/.last-collection"
    fi

    # Release lockfile (trap will also clean up)
    rmdir "$LOCKFILE" 2>/dev/null || true
    fi  # end of DAYS_AWAY > 1 inner guard

    GAP_CONTEXT="The developer was away for $DAYS_AWAY days. A catch-up rollup was just generated. Frame the briefing as a 'welcome back' — summarize the catch-up, then suggest where to re-enter."
    echo ""
elif [[ "$LAST_ROLLUP_DATE" == "none" ]] || [[ "$LAST_ROLLUP_DATE" == "genesis" ]]; then
    GAP_CONTEXT="This project only has a genesis rollup — no daily rollups yet. The briefing should orient the developer to the project state from the genesis rollup and suggest first priorities."
fi

# --- Gather context for briefing ---
STATE=$(cat "$WORKSPACE/state.md")
LATEST_ROLLUP=""
LATEST_EP=$(find "$WORKSPACE/episodes" -name "*.md" -print 2>/dev/null | sort -r | head -1)
if [[ -n "${LATEST_EP:-}" ]] && [[ -f "$LATEST_EP" ]]; then
    LATEST_ROLLUP=$(cat "$LATEST_EP")
fi

PROTOCOL_TEXT=""
if [[ -f "$PROTOCOL" ]]; then
    PROTOCOL_TEXT=$(cat "$PROTOCOL")
fi

# --- Launch interactive session ---
SESSION_MARKER="$MORNING_DIR/${TODAY}.started"

SYSTEM_CONTEXT="$PROTOCOL_TEXT

## Current Project State
$STATE

## Latest Rollup
$LATEST_ROLLUP

## Gap Context
$GAP_CONTEXT

## Morning Session
This is a morning briefing session. The developer just sat down. Greet them with a concise briefing based on the state and latest rollup. Then stay in conversation — they may want to discuss priorities, ask questions, or plan today.

This conversation will be saved to the project's mornings/ folder for future reference."

# Resume existing session or start fresh
if [[ -f "$SESSION_MARKER" ]]; then
    echo "Resuming morning session for $PROJECT..."
    echo ""
    exec claude --continue \
        2> >(tee -a "$MORNING_DIR/${TODAY}.log" >&2)
else
    echo "Starting Axon morning session for $PROJECT..."
    echo ""
    touch "$SESSION_MARKER"
    exec claude \
        --append-system-prompt "$SYSTEM_CONTEXT" \
        2> >(tee -a "$MORNING_DIR/${TODAY}.log" >&2)
fi
