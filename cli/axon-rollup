#!/usr/bin/env bash
# axon-rollup — Collect dendrites + produce nightly rollup via Claude
# The core daily loop: gather signals, synthesize, update state

set -euo pipefail

AXON_HOME="${AXON_HOME:-$HOME/.axon}"
PROJECT="${PROJECT:-$(basename "$PWD")}"
PROJECT_PATH="${PROJECT_PATH:-$PWD}"
WORKSPACE="$AXON_HOME/workspaces/$PROJECT"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROTOCOL="${PROTOCOL:-$SCRIPT_DIR/../protocol.md}"
TODAY=$(date +%Y-%m-%d)

# Check initialized
if [[ ! -f "$WORKSPACE/state.md" ]]; then
    echo "Project '$PROJECT' is not initialized. Run: axon init --project $PROJECT --path $PROJECT_PATH"
    exit 1
fi

# Lockfile — prevent concurrent rollups
LOCKFILE="$WORKSPACE/.rollup.lock"
FORCE="${FORCE:-}"

if ! mkdir "$LOCKFILE" 2>/dev/null; then
    # Check lock age — stale if older than 30 minutes
    LOCK_AGE=0
    if [[ -d "$LOCKFILE" ]]; then
        if [[ "$(uname)" == "Darwin" ]]; then
            LOCK_CREATED=$(stat -f %m "$LOCKFILE" 2>/dev/null || echo "0")
        else
            LOCK_CREATED=$(stat -c %Y "$LOCKFILE" 2>/dev/null || echo "0")
        fi
        NOW_EPOCH=$(date +%s)
        LOCK_AGE=$(( NOW_EPOCH - LOCK_CREATED ))
    fi

    if [[ -n "$FORCE" ]]; then
        echo "WARNING: Forcing past stale lock (age: ${LOCK_AGE}s)"
        rmdir "$LOCKFILE" 2>/dev/null || true
        mkdir "$LOCKFILE"
    elif [[ "$LOCK_AGE" -gt 1800 ]]; then
        echo "Stale lock detected (${LOCK_AGE}s old). Removing..."
        rmdir "$LOCKFILE" 2>/dev/null || true
        mkdir "$LOCKFILE"
    else
        echo "Another rollup is in progress (lock age: ${LOCK_AGE}s)."
        echo "If stale, run with: FORCE=1 axon rollup"
        exit 1
    fi
fi
trap 'rmdir "$LOCKFILE" 2>/dev/null' EXIT INT TERM

ROLLUP_START=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
echo "=== Axon Rollup: $PROJECT ($TODAY) ==="
echo "[axon-rollup] start=$ROLLUP_START project=$PROJECT"
echo ""

# Step 1: Collect dendrites (don't update .last-collection yet — wait for rollup success)
echo "Step 1: Collecting dendrites..."
export PROJECT PROJECT_PATH AXON_HOME SINCE
"$SCRIPT_DIR/axon-collect"
echo ""

# Step 2: Gather context for rollup
echo "Step 2: Assembling rollup context..."

STATE=$(cat "$WORKSPACE/state.md")

# Get recent episodes for continuity (last 3)
RECENT_EPISODES=""
while IFS= read -r ep; do
    [[ -z "$ep" ]] && continue
    RECENT_EPISODES+="
---
### $(basename "$ep")
$(head -60 "$ep")
...
"
done < <(find "$WORKSPACE/episodes" -name "*.md" -print 2>/dev/null | sort -r | head -3)

# Get recent dendrites (from today's collection)
DENDRITES=""
while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    DENDRITES+="
$(cat "$d")
---
"
done < <(find "$WORKSPACE/dendrites" -name "*.md" -print 2>/dev/null | sort -r | head -10)

if [[ ! -f "$PROTOCOL" ]]; then
    echo "FATAL: protocol.md not found at $PROTOCOL"
    echo "[axon-rollup] end=$(date -u +"%Y-%m-%dT%H:%M:%SZ") project=$PROJECT status=failed error=no_protocol"
    exit 1
fi
PROTOCOL_TEXT=$(cat "$PROTOCOL")

DENDRITE_COUNT=$(find "$WORKSPACE/dendrites" -name "*.md" -print 2>/dev/null | wc -l | tr -d ' ')
EPISODE_COUNT=$(find "$WORKSPACE/episodes" -name "*.md" -print 2>/dev/null | wc -l | tr -d ' ')
echo "  ✓ State loaded"
echo "  ✓ $DENDRITE_COUNT dendrite files"
echo "  ✓ $EPISODE_COUNT previous episodes"

if [[ -z "$DENDRITES" ]]; then
    echo "FATAL: No dendrite signals found. Cannot produce a meaningful rollup."
    echo "[axon-rollup] end=$(date -u +"%Y-%m-%dT%H:%M:%SZ") project=$PROJECT status=failed error=no_dendrites"
    exit 1
fi
echo ""

# Dry run — show prompt without calling Claude
if [[ -n "${DRY_RUN:-}" ]]; then
    echo "=== DRY RUN — Prompt that would be sent ==="
    echo "Protocol: $(echo "$PROTOCOL_TEXT" | wc -w | tr -d ' ') words"
    echo "State: $(echo "$STATE" | wc -w | tr -d ' ') words"
    echo "Episodes context: $(echo "$RECENT_EPISODES" | wc -w | tr -d ' ') words"
    echo "Dendrites: $(echo "$DENDRITES" | wc -w | tr -d ' ') words"
    echo "Total prompt: ~$(echo "$PROTOCOL_TEXT$STATE$RECENT_EPISODES$DENDRITES" | wc -w | tr -d ' ') words"
    exit 0
fi

# Step 3: Call Claude for rollup
echo "Step 3: Generating rollup..."
echo ""

CLAUDE_STDERR=$(mktemp)
ROLLUP_RESULT=$(echo "You are Axon, running in headless mode. Produce the nightly rollup for '$PROJECT'.

## Protocol
$PROTOCOL_TEXT

## Current State
$STATE

## Recent Episodes (for continuity)
$RECENT_EPISODES

## Today's Dendrite Signals
$DENDRITES

## Task
Produce today's rollup. Start with YAML frontmatter, then markdown sections.

### YAML Frontmatter (REQUIRED)
\`\`\`
---
type: rollup
date: $TODAY
project: $PROJECT
headline: \"<one punchy line summarizing the day — max 80 chars>\"
tags: [<2-4 from: shipping, hardening, testing, bugfix, architecture, blocked, concurrency, compliance, refactor, docs>]
energy: <high|medium|low — based on commit velocity and scope of changes>
momentum: <accelerating|steady|decelerating — compared to recent days>
commits: <number>
decisions: <number of decision traces>
open_loops: <number of unfinished items>
risk_items: <number of items flagged as risky>
---
\`\`\`

### Sections
1. **Summary** — 2-3 sentences, specific numbers and names
2. **Momentum** — one paragraph: is this project accelerating, steady, or decelerating? Compare today's output to recent rollups. Note velocity changes, scope shifts, or signs of being stuck. Be honest — "you shipped 3 features but none have tests" is useful. End with a directional word: accelerating, cruising, stalling, or blocked.
3. **Key Decisions** — use the Decision Trace format. Number each decision with a globally unique ID: DT-YYYYMMDD-N where YYYYMMDD is today's date ($TODAY without dashes) and N is a sequential number starting at 1. For example: DT-$(date +%Y%m%d)-1, DT-$(date +%Y%m%d)-2, etc.
   - **Input:** what triggered the decision
   - **Constraint:** what limited the options
   - **Tradeoff:** what was weighed
   - **Decision:** what was chosen and why
4. **Files Most Touched** — top 5-10 with context
5. **Unfinished Work** — use [ ] for new items, [>] for carried from previous rollups
6. **Risk Flags** — items that need attention:
   - Any item carried for >3 days without progress: flag it with ⚠️ and recommend: decide, delegate, or drop
   - Any code shipped without tests: flag it
   - Any TODO/FIXME in hot files
   - If nothing is risky, say so in one line
7. **Continuity** — what was done from yesterday's open items, what carries forward
8. **Recommended Next Steps** — rank by LEVERAGE, not recency. For each:
   - What to do (specific, actionable)
   - Why it matters now (what it unblocks or what risk it reduces)
   - Estimated scope (quick win / half-day / multi-day)
   Don't just summarize — have an opinion. If something should be dropped, say so. If something is being avoided, call it out.

### Tone
Be conversational but precise. Reference specific files, commits, and sessions. You are a sharp colleague reviewing the day's work — not a summarizer. Say what matters, why it matters, and what the developer should do about it.

### Verification (CRITICAL)
You have access to Read, Glob, and Grep tools. The dendrites above are compressed summaries — they are LEADS, not ground truth. Before making ANY claim about what exists or doesn't exist in the codebase:

1. **Never assert absence without checking.** If dendrites don't mention tests, that doesn't mean there are no tests. Use \`Glob\` or \`Grep\` to verify: e.g. \`Glob('**/test_*.py')\`, \`Grep('def test_', type='py')\`.
2. **Sanity-check key claims.** Before writing "zero test coverage on X", grep for test files related to X. Before writing "no CI pipeline", check for .github/workflows or similar.
3. **Cross-reference the file tree.** The dendrite has directory file counts. If you see \`backend/tests/e2e/: 18 files\`, there ARE tests there — read a few to understand coverage.
4. **Don't assume unchanged = absent.** Files not touched since the last rollup still exist. The dendrite shows what changed, not everything that exists.
5. **Be a journalist, not a summarizer.** Verify before publishing. If you're not sure about a claim, check the codebase. A wrong claim in a rollup erodes trust in the entire system.

The project path is: $PROJECT_PATH

IMPORTANT: Output ONLY the rollup document. No preamble, no meta-commentary, no notes about your process. Start with the YAML frontmatter (---) and end with the last section. Do not mention files you wrote, tools you used, or sandbox limitations." | claude -p --output-format json --allowedTools "Read,Glob,Grep" 2>"$CLAUDE_STDERR")

# Validate response is valid JSON with a .result field
if ! echo "$ROLLUP_RESULT" | jq -e '.result' > /dev/null 2>&1; then
    echo "FATAL: Claude returned invalid response (not JSON or missing .result)"
    [[ -s "$CLAUDE_STDERR" ]] && echo "Claude stderr:" && cat "$CLAUDE_STDERR"
    echo "Raw response (first 500 chars):"
    echo "$ROLLUP_RESULT" | head -c 500
    echo "[axon-rollup] end=$(date -u +"%Y-%m-%dT%H:%M:%SZ") project=$PROJECT status=failed error=invalid_json"
    rm -f "$CLAUDE_STDERR"
    exit 1
fi

RAW_TEXT=$(echo "$ROLLUP_RESULT" | jq -r '.result')

if [[ -z "$RAW_TEXT" ]] || [[ "$RAW_TEXT" == "null" ]]; then
    echo "FATAL: Claude returned empty rollup."
    [[ -s "$CLAUDE_STDERR" ]] && echo "Claude stderr:" && cat "$CLAUDE_STDERR"
    echo "[axon-rollup] end=$(date -u +"%Y-%m-%dT%H:%M:%SZ") project=$PROJECT status=failed error=empty_result"
    rm -f "$CLAUDE_STDERR"
    exit 1
fi
rm -f "$CLAUDE_STDERR"

# Sanitize Claude output:
# 1. Strip preamble before the first --- delimiter
# 2. Unwrap code-fenced frontmatter (```yaml\n---\n...\n---\n```)
ROLLUP_TEXT="$RAW_TEXT"

# Strip preamble — find the first YAML frontmatter delimiter
if ! echo "$ROLLUP_TEXT" | head -1 | grep -q "^---"; then
    echo "  ⚠ Stripping preamble from Claude output..."
    ROLLUP_TEXT=$(echo "$ROLLUP_TEXT" | sed -n '/^---$/,$p')
fi

# Unwrap code-fenced frontmatter and stray separators
# Strategy: find the line "type: rollup" and work backwards to the --- before it
if echo "$ROLLUP_TEXT" | grep -q '```'; then
    echo "  ⚠ Unwrapping code-fenced frontmatter..."
    ROLLUP_TEXT=$(echo "$ROLLUP_TEXT" | sed '/^```\(yaml\)\{0,1\}$/d')
fi
# Find the --- that immediately precedes "type: rollup" — that's the real frontmatter start
# Then take everything from that --- onwards
FRONTMATTER_LINE=$(echo "$ROLLUP_TEXT" | grep -n "^type: rollup" | head -1 | cut -d: -f1)
if [[ -n "$FRONTMATTER_LINE" ]] && [[ "$FRONTMATTER_LINE" -gt 1 ]]; then
    # Walk backwards from "type: rollup" to find the opening ---
    SEARCH_START=$((FRONTMATTER_LINE - 3))
    [[ "$SEARCH_START" -lt 1 ]] && SEARCH_START=1
    START_LINE=$(echo "$ROLLUP_TEXT" | sed -n "${SEARCH_START},$((FRONTMATTER_LINE - 1))p" | grep -n "^---$" | tail -1 | cut -d: -f1)
    if [[ -n "$START_LINE" ]]; then
        ACTUAL_START=$(( SEARCH_START + START_LINE - 1 ))
        ROLLUP_TEXT=$(echo "$ROLLUP_TEXT" | tail -n +"$ACTUAL_START")
    fi
fi

# Validate frontmatter exists after cleanup
TRIMMED=$(echo "$ROLLUP_TEXT" | sed '/^$/d' | head -1)
if [[ "$TRIMMED" != "---" ]]; then
    echo "FATAL: Rollup doesn't contain YAML frontmatter (first line: ${TRIMMED:0:80})"
    echo "  Claude output meta-commentary instead of the rollup document."
    echo "[axon-rollup] end=$(date -u +"%Y-%m-%dT%H:%M:%SZ") project=$PROJECT status=failed error=no_frontmatter"
    exit 1
fi

# Validate minimum size (a real rollup is >500 bytes)
ROLLUP_SIZE=${#ROLLUP_TEXT}
if [[ "$ROLLUP_SIZE" -lt 500 ]]; then
    echo "FATAL: Rollup too small (${ROLLUP_SIZE} bytes). Expected >500 for a real rollup."
    echo "[axon-rollup] end=$(date -u +"%Y-%m-%dT%H:%M:%SZ") project=$PROJECT status=failed error=too_small"
    exit 1
fi

# Step 4: Write outputs (same-day protection)
EPISODE_FILE="$WORKSPACE/episodes/${TODAY}_rollup.md"
if [[ -f "$EPISODE_FILE" ]]; then
    EPISODE_FILE="$WORKSPACE/episodes/${TODAY}_rollup_$(date +%H%M%S).md"
fi

# Write to temp first, then move (atomic)
TMPFILE=$(mktemp "$WORKSPACE/episodes/.tmp.XXXXXX")
echo "$ROLLUP_TEXT" > "$TMPFILE" && mv "$TMPFILE" "$EPISODE_FILE"
echo "  ✓ Rollup → $(basename "$EPISODE_FILE")"

# Update .last-collection NOW — rollup succeeded, safe to advance the window
LAST_FILE="$WORKSPACE/dendrites/.last-collection"
date -u +"%Y-%m-%dT%H:%M:%SZ" > "$LAST_FILE"

# Step 5: Update state.md via Claude
echo ""
echo "Step 5: Updating state..."

CLAUDE_STDERR2=$(mktemp)
NEW_STATE=$(echo "You are Axon. Given this rollup and the previous state, produce an updated state.md.

## Previous State
$STATE

## Today's Rollup
$ROLLUP_TEXT

## Task
Regenerate state.md. MUST stay under 2000 tokens. If exceeding, prune decisions older than 14 days, compress timeline, archive completed items. Include:
- What This Project Is (keep stable, rarely changes)
- Current Focus (update based on rollup)
- Where Things Stand (compact status per workstream)
- Active Decisions (recent decisions with dates)
- Open Loops (checklist — merge old + new, mark completed with [x])
- Blockers
- Suggested Next Move
- Key Files table
- Recent Timeline (last 5-7 days, one line each)

Add YAML frontmatter: type: state, project: $PROJECT, last_rollup: $TODAY

IMPORTANT: Output ONLY the state.md content. No preamble, no meta-commentary, no explanation of changes. Start with the YAML frontmatter (---) and end with the last section." | claude -p --output-format json 2>"$CLAUDE_STDERR2" | jq -r '.result' 2>/dev/null)
rm -f "$CLAUDE_STDERR2"

# Strip preamble from state output
if [[ -n "$NEW_STATE" ]] && [[ "$NEW_STATE" != "null" ]]; then
    if ! echo "$NEW_STATE" | head -1 | grep -q "^---"; then
        NEW_STATE=$(echo "$NEW_STATE" | sed -n '/^---$/,$p')
    fi
fi

if [[ -n "$NEW_STATE" ]] && [[ "$NEW_STATE" != "null" ]]; then
    cp "$WORKSPACE/state.md" "$WORKSPACE/state.md.backup"
    TMPSTATE=$(mktemp "$WORKSPACE/.state.tmp.XXXXXX")
    echo "$NEW_STATE" > "$TMPSTATE" && mv "$TMPSTATE" "$WORKSPACE/state.md"
    echo "  ✓ State updated (atomic write, backup at state.md.backup)"
else
    echo "  WARNING: State update failed (keeping previous state)"
    echo "[axon-rollup] state_update=failed project=$PROJECT"
fi

# Log it
echo "- [$(date -u +"%Y-%m-%dT%H:%M:%SZ")] @axon: Rollup committed: $TODAY → $(basename "$EPISODE_FILE")" >> "$WORKSPACE/stream.md"

# Step 6: Regenerate Gource visual fingerprint (if gource + ffmpeg available)
if command -v gource &>/dev/null && command -v ffmpeg &>/dev/null && [[ -d "$PROJECT_PATH/.git" ]]; then
    echo "  Regenerating Gource fingerprint..."
    if gource --window-position 5000x5000 --frameless -1920x1080 \
        --stop-at-end -s 0.001 --auto-skip-seconds 0.001 \
        --hide bloom,mouse,progress,filenames,dirnames,usernames,date \
        --background 000000 -o - --output-framerate 25 "$PROJECT_PATH" 2>/dev/null \
        | ffmpeg -y -f image2pipe -vcodec ppm -i - -update 1 "$WORKSPACE/gource.png" 2>/dev/null; then
        echo "  ✓ Gource fingerprint updated"
    else
        echo "  ⚠ Gource generation failed (non-fatal)"
    fi
fi

# Step 7: Auto-commit to Axon git repo
if [[ -d "$AXON_HOME/.git" ]]; then
    if ! git -C "$AXON_HOME" add "workspaces/$PROJECT/" 2>&1; then
        echo "  WARNING: Failed to stage rollup in Axon git repo"
    elif ! git -C "$AXON_HOME" diff --cached --quiet 2>/dev/null; then
        if git -C "$AXON_HOME" commit -m "rollup: $PROJECT $TODAY" --quiet 2>&1; then
            echo "  ✓ Committed to Axon history"
        else
            echo "  WARNING: Failed to commit rollup to Axon git repo"
        fi
    fi
fi

# Show cost
COST=$(echo "$ROLLUP_RESULT" | jq '.total_cost_usd // empty' 2>/dev/null)
ROLLUP_END=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
echo ""
echo "=== Done ==="
echo "  Rollup:  $EPISODE_FILE"
echo "  State:   $WORKSPACE/state.md"
echo "  Cost:    \$${COST:-unknown}"
echo "[axon-rollup] end=$ROLLUP_END project=$PROJECT episode=$(basename "$EPISODE_FILE") cost=${COST:-unknown} status=success"
echo ""
echo "Run 'axon morning --project $PROJECT' tomorrow for your briefing."
